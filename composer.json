{
  "name": "voxelsite/voxelswarm",
  "description": "VoxelSite instance provisioning and management. Plain PHP, SQLite, two dependencies.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "symfony/process": "^7.0",
    "phpmailer/phpmailer": "^6.9"
  },
  "autoload": {
    "psr-4": {
      "Swarm\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
