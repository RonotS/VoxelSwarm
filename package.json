{
  "name": "voxelswarm",
  "version": "1.0.0",
  "private": true,
  "description": "VoxelSwarm — development tooling (not shipped to buyers)",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./ui/src/swarm.src.css -o ./build/swarm.css --minify",
    "build": "npm run build:css",
    "watch:css": "npx @tailwindcss/cli -i ./ui/src/swarm.src.css -o ./build/swarm.css --watch",
    "watch": "npm run watch:css",
    "icons": "mkdir -p ./icons && cp ./node_modules/lucide-static/icons/*.svg ./icons/"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "lucide-static": "^0.563.0",
    "tailwindcss": "^4.2.1"
  }
}
